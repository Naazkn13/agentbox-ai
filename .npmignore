# ── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*/__pycache__/
*/*/__pycache__/
*/*/*/__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw

# ── Sensitive / local-only files ─────────────────────────────────────────────
tokens.txt
.env
*.secret
logs.txt
agentkit-deep-dive.jsx

# ── Local state directories (generated at runtime, not source) ───────────────
.agentkit/
data/
plans/

# ── Developer docs (local tracking) ─────────────────────────────────────────
STATUS.md

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
*.tgz
npm-debug.log*
.npm/
package-lock.json

# ── Version control + npm meta ───────────────────────────────────────────────
.git/
.gitignore
.npmignore
