# ── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*/__pycache__/
*/*/__pycache__/
*/*/*/__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw

# ── IDE / editor config ──────────────────────────────────────────────────────
.claude/
.vscode/
.idea/

# ── Sensitive / local-only files ─────────────────────────────────────────────
tokens.txt
.env
*.secret
logs.txt
agentkit-deep-dive.jsx
cli/create-issues.sh
cli/create_issues.py

# ── Local state directories (generated at runtime, not source) ───────────────
# Use leading / to anchor to package root only — avoids excluding skills/data/, skills/plans/ etc.
.agentkit/
/data/
/plans/

# ── Developer docs (local tracking) ─────────────────────────────────────────
STATUS.md

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
*.tgz
npm-debug.log*
.npm/
package-lock.json

# ── Version control + npm meta ───────────────────────────────────────────────
.git/
.gitignore
.npmignore
