{
  "_comment": "AgentKit reference template — DO NOT copy this file manually. Run `npx agentkit init` instead. Claude Code does NOT expand ${VAR} in hook commands — only absolute paths work.",
  "_agentkit_version": "0.5.9",

  "_usage": "Run `npx agentkit init` — it writes absolute paths into ~/.claude/settings.json automatically.",

  "hooks": {
    "_note": "Replace /ABSOLUTE/PATH/TO/agentkit with the actual install path. Run `npx agentkit init` to do this automatically.",
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /ABSOLUTE/PATH/TO/agentkit/hooks/spawn_hook.py"
          },
          {
            "type": "command",
            "command": "python3 /ABSOLUTE/PATH/TO/agentkit/hooks/skill_router_hook.py"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/session_start.sh"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/memory_inject.sh"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/model_router_hook.sh"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/thinking_budget.sh"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/workflow_state.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/forced_eval.sh"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/plan_gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/research_gate.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/memory_recorder.sh"
          },
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/cost_dashboard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/quality_gates.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /ABSOLUTE/PATH/TO/agentkit/hooks/session_end.sh"
          }
        ]
      }
    ]
  }
}
