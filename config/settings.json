{
  "_comment": "AgentKit Claude Code settings template. Copy relevant sections into your .claude/settings.json",
  "_agentkit_version": "0.4.0",

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${AGENTKIT_HOME}/hooks/skill_router_hook.py"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/session_start.sh"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/memory_inject.sh"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/model_router_hook.sh"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/thinking_budget.sh"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/workflow_state.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/forced_eval.sh"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/plan_gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/research_gate.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/memory_recorder.sh"
          },
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/cost_dashboard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/quality_gates.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${AGENTKIT_HOME}/hooks/session_end.sh"
          }
        ]
      }
    ]
  },

  "_notes": {
    "AGENTKIT_HOME": "Set this env var to the absolute path of your AgentKit install dir",
    "UserPromptSubmit": "Skill router + session handoff + memory + model router + thinking budget + workflow state",
    "PreToolUse (Edit)": "Forced-eval + plan gate — blocks coding without an approved plan",
    "PostToolUse (Read)": "Research gate — tracks file reads for RESEARCH→PLAN transition",
    "PostToolUse (Edit)": "Memory + cost dashboard + quality gates (syntax/lint/types/tests)",
    "Stop": "Session end — compresses session into handoff document via Haiku"
  }
}
